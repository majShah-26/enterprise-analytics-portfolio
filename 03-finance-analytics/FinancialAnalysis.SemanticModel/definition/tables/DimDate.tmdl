	partition DimDate = calculated
		mode: import
		source = ```
				
				VAR BaseCalendar = 
				    CALENDAR(
				        DATE(2024, 1, 1), 
				        DATE(2025, 12, 31)
				    )
				RETURN
				    ADDCOLUMNS(
				        BaseCalendar,
				        "DateKey", INT(FORMAT([Date], "YYYYMMDD")),
				        "Year", YEAR([Date]),
				        "MonthNumber", MONTH([Date]),
				        "MonthName", FORMAT([Date], "MMMM"),
				        "MonthShort", FORMAT([Date], "MMM"),
				        "Quarter", "Q" & FORMAT([Date], "Q"),
				        "YearMonth", FORMAT([Date], "YYYY-MM")
				    )
				```

	annotation PBI_Id = 4737fa5b30e0487cacc659ceb36a333f

