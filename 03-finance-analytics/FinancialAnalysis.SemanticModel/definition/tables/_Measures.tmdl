table _Measures
	lineageTag: 191b3da7-3028-41b2-9e46-44a7aeb39913

	measure TotalBudget = ```
			COALESCE(SUM(FactBudgetExecution[AllocatedBudget]), 0)
			
			```
		formatString: #,0
		lineageTag: bd90c528-aaaf-475f-9a87-fbc532b6131f

	measure TotalActualSpend = ```
			COALESCE(SUM(FactBudgetExecution[ActualSpend]), 0)
			
			```
		formatString: #,0
		lineageTag: 05e4818d-3cef-4044-9256-8065e56bacd1

		annotation PBI_FormatHint = {"isDecimal":true}

	measure BudgetVariance = ```
			[TotalBudget] - [TotalActualSpend]
			
			```
		formatString: #,0
		lineageTag: 0de665a2-5867-46ef-a823-70cbff11253c

		annotation PBI_FormatHint = {"isDecimal":true}

	measure BudgetBurnRate_Pct = ```
			
			DIVIDE(
			    [TotalActualSpend], 
			    [TotalBudget], 
			    0
			)
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 07935cea-0091-4194-b849-55e02778debe

